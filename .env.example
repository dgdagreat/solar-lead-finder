# ──────────────────────────────────────────────────────────────────────────
# Solar Lead Finder — environment variables
# Copy to `.env`:   cp .env.example .env
#
# NOTE: every key below is OPTIONAL. With no keys set, the app runs on
# realistic MOCK data so you can demo the whole pipeline without signing up
# for anything. Add keys to pull live property data + real satellite imagery.
# ──────────────────────────────────────────────────────────────────────────

# Django secret key — any random string is fine for local development.
SECRET_KEY=change-me-to-a-random-string

# Set True for local development (debug pages + local static/media serving).
# Leave False / unset in production.
DJANGO_DEBUG=True

# Google Maps Static API — fetches the zoom-20 satellite image of each rooftop.
# Without it, the satellite + detection steps are skipped.
GOOGLE_STREET_VIEW_API_KEY=

# Property data source #1 — Realty in US (RapidAPI): recently-sold homes.
RAPIDAPI_KEY=

# Property data source #2 — ATTOM Data (used only if RAPIDAPI_KEY is unset).
ATTOM_API_KEY=

# Celery broker / result backend — only needed if you run async workers.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
